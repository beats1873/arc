DISCORD_TOKEN=
CLIENT_ID=
GUILD_ID=
KAWAII_API_KEY=

# Logging level: DEBUG | INFO | WARN | ERROR (default: INFO)
# Set to DEBUG for verbose output during troubleshooting
LOG_LEVEL=INFO

# Dashboard settings (http://localhost:3001 by default)
# CLIENT_SECRET is found in Discord Developer Portal → OAuth2 → Client Secret
CLIENT_SECRET=
# DASHBOARD_URL must exactly match the OAuth2 Redirect URI you add in the Discord portal
DASHBOARD_URL=http://localhost:3001
DASHBOARD_PORT=3001

# When running with Docker Compose, MONGO_URI is set automatically.
# When running without Docker, set this manually:
# MONGO_URI=mongodb://localhost:27017/arcturus
MONGO_URI=
